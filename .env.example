# Copy this file to .env on your EC2 server and fill in real values.
# docker compose automatically reads .env from the same directory.

# PostgreSQL password (choose a strong random value)
DB_PASSWORD=change-me-use-something-random

# Express session secret (must be at least 32 characters)
SESSION_SECRET=change-me-to-a-long-random-string-minimum-32-chars

# Set to "true" if the app is served over HTTPS (e.g. behind an SSL load balancer or Nginx)
COOKIE_SECURE=false
